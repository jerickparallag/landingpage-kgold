# Future Greenhouse / careers board API (optional)
VITE_CAREERS_API_URL=

# Chat assistant
VITE_CHAT_ENABLED=true
VITE_CHAT_ADAPTER=gemini
VITE_CHAT_API_URL=/api/chat

# Gemini — SERVER ONLY (never use VITE_ prefix; not exposed to the browser)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Static-only mode (no Gemini):
# VITE_CHAT_ADAPTER=static
